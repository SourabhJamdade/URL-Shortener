<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Analytics</title>
    <style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #1f1f1f;
        color: #ffffff;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    h1 {
        text-align: center;
        margin-top: 20px;
    }
    .analytics {
        margin-top: 50px;
        width: 60%;
    }
    table {
        width: 100%;
        border-collapse: collapse;
    }
    th, td {
        border: 1px solid #333;
        padding: 10px;
        text-align: left;
    }
    th {
        background-color: #2c2c2c;
    }
    </style>
  </head>
  <body>
    
      <div class="analytics">
        <h1>Analytics</h1>
        <% if (locals.urls) { %>
            <table>
                <thead>
                <tr>
                    <th>Sr. No</th>
                    <th>Shortened URL</th>
                    <th>Original URL</th>
                    <th>Total Clicks</th>
                </tr>
                </thead>
                <tbody>
                <% urls.forEach((url, index) => { %>
                    <tr>
                    <!-- Added "=" to render the values -->
                    <td><%= index + 1 %></td>
                    <td><%= url.shortId %></td>
                    <td><%= url.redirectURL %></td>
                    <td><%= url.visitHistory.length %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
  </body>
</html>
